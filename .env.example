# Copy this file to .env and fill in your values.
# NEVER commit the real .env file.

# Anthropic — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ElevenLabs — https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# Pexels — https://www.pexels.com/api/
PEXELS_API_KEY=

# YouTube OAuth2 — see README: Google Cloud Console setup
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# Instagram / Facebook — see README: Meta Developer setup
IG_USER_ID=
IG_ACCESS_TOKEN=
FB_APP_ID=
FB_APP_SECRET=

# Cloudflare R2 — see README: R2 setup
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=

# Telegram — see README: bot setup
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
